{
  "name": "coffee-blog-pipeline",
  "version": "1.0.0",
  "description": "AI-powered coffee blog post generator for note.com",
  "private": true,
  "scripts": {
    "prepare": "git config core.hooksPath .githooks && chmod +x .githooks/pre-commit",
    "generate": "ts-node scripts/generate-post.ts",
    "generate:dry": "ts-node scripts/generate-post.ts --dry-run",
    "matrix": "ts-node scripts/generate-from-matrix.ts",
    "matrix:dry": "ts-node scripts/generate-from-matrix.ts --dry-run",
    "matrix:batch": "ts-node scripts/generate-from-matrix.ts --count",
    "matrix:status": "ts-node scripts/generate-from-matrix.ts --status",
    "post": "ts-node scripts/post-to-note.ts",
    "pipeline": "ts-node scripts/run-pipeline.ts",
    "lint": "eslint scripts/**/*.ts",
    "lint:fix": "eslint scripts/**/*.ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "pm": "ts-node scripts/pm-report.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.0",
    "openai": "^4.80.0",
    "playwright": "^1.50.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.61.0"
  }
}
