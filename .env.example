# GitHub Models (GPT-4o) — ローカル実行時のみ必要
# GitHub Actions では GITHUB_TOKEN が自動提供されるため不要
# 取得方法: GitHub → Settings → Developer settings → Personal access tokens
GITHUB_TOKEN=your_github_personal_access_token_here

# note.com API トークン
# 取得方法: noteにログイン後、DevTools(F12) → Network → api.note.com へのリクエスト
#           → Request Headers の "Authorization: Bearer xxxxx" からコピー
NOTE_API_TOKEN=your_note_api_token_here
